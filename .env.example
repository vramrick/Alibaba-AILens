# AI Lens Environment Configuration
# Copy this file to .env and update the values for your environment

# === Basic Settings ===
ENVIRONMENT=development
DEBUG=false

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === OpenTelemetry ===
OTEL_SERVICE_NAME=ai-lens-backend
OTEL_SERVICE_VERSION=0.1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACE_SAMPLE_RATE=1.0

# === Gateway (open-gateway service) ===
# URL of the running open-gateway instance
TRACEQL_BASE_URL=http://localhost:8080
TRACEQL_AUTH_KEY=

# === ClickHouse (used by gateway) ===
CLICKHOUSE_URL=jdbc:clickhouse://localhost:8123/default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
